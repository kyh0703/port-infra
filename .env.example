# Default local Docker environment.
# Copy to .env and override only values that differ on your machine.

# Compose host ports
API_PORT=3001
WEB_PORT=3000
REDIS_PORT=6379

# API runtime
NODE_ENV=local
PORT=3001
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=debug
DB_PATH=/app/data/dubu.sqlite
REDIS_URL=redis://redis:6379

# Web runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Auth
JWT_ACCESS_TOKEN_SECRET=dubu_exec_local_access_token_secret_change_me
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=dubu_exec_local_refresh_token_secret_change_me
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Email verification
EMAIL_VERIFICATION_DEV_CODE=true

# SMTP
EMAIL_HOST=mail.iproncloud.kr
EMAIL_PORT=25
EMAIL_ADDRESS=service@iproncloud.kr
EMAIL_PASSWORD=<set-in-local-env>
EMAIL_SECURE=false

# OpenAI Realtime
OPENAI_API_KEY=<set-in-local-env>
