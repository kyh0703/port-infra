# Default local Docker environment.
# Copy to .env and override only values that differ on your machine.

# Compose host ports
API_PORT=3001
MEDIA_PORT=8080
WEB_PORT=3000
REDIS_PORT=16379

# API runtime
NODE_ENV=local
NODE_ID=1
PORT=3001
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=debug
DB_PATH=/app/data/overthinker.sqlite
REDIS_URL=redis://redis:6379

# Media runtime
MEDIA_NODE_ID=2
MEDIA_SERVER_PUBLIC_URL=http://localhost:8080
MEDIA_TOKEN_TTL=60s
MEDIA_SERVER_REQUEST_TIMEOUT_MS=5000
MEDIA_CONVERSATION_EVENT_STREAM=media:conversation-events:v1
MEDIA_CONVERSATION_EVENT_GROUP=port-api
MEDIA_CONVERSATION_EVENT_READ_BATCH_SIZE=10
MEDIA_CONVERSATION_EVENT_READ_BLOCK_MS=5000
MEDIA_CONVERSATION_EVENT_PENDING_MIN_IDLE_MS=30000
MEDIA_CONVERSATION_EVENT_RETRY_LIMIT=5

# Web runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_REALTIME_ICE_SERVERS=

# Auth
JWT_ACCESS_TOKEN_SECRET=overthinker_local_access_token_secret_change_me
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=overthinker_local_refresh_token_secret_change_me
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Email verification SMTP
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_ADDRESS=your-email@example.com
EMAIL_PASSWORD=your-email-app-password
EMAIL_SECURE=false
EMAIL_VERIFICATION_DEBUG_CODE=true

# OpenAI Realtime
OPENAI_API_KEY=your-openai-api-key
