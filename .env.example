# Default local Docker environment.
# Copy to .env and override only values that differ on your machine.

# Compose host ports
REDIS_PORT=16379
POSTGRES_PORT=15432
PGADMIN_PORT=5050

# PostgreSQL
POSTGRES_DB=port
POSTGRES_USER=port
POSTGRES_PASSWORD=port_local_password

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
