# Default local Docker environment.
# Copy to .env and override only values that differ on your machine.

# Compose host ports
API_PORT=3001
WEB_PORT=3000
REDIS_PORT=16379

# API runtime
NODE_ENV=local
PORT=3001
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=debug
DB_PATH=/app/data/dubu.sqlite
REDIS_URL=redis://redis:6379

# Web runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Auth
JWT_ACCESS_TOKEN_SECRET=dubu_exec_local_access_token_secret_change_me
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=dubu_exec_local_refresh_token_secret_change_me
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Email verification SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_ADDRESS=your-email@example.com
EMAIL_PASSWORD=your-email-app-password
EMAIL_SECURE=true

# OpenAI Realtime
OPENAI_API_KEY=your-openai-api-key
